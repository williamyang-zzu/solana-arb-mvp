# Mainnet RPC. Use a paid RPC for better simulation/debugging.
RPC_URL=https://api.mainnet-beta.solana.com

# Choose one wallet loading mode:
# 1) base58 private key, e.g. exported from Phantom/Backpack
# PRIVATE_KEY_BASE58=

# 2) local keypair json path, e.g. ~/.config/solana/id.json
KEYPAIR_PATH=~/.config/solana/id.json

# Fixed MVP pair settings.
# For first version, hardcode one Pumpfun graduated token and its two pools.
TOKEN_MINT=
PUMP_POOL=
DLMM_PAIR=

# Amount and slippage.
INPUT_SOL=0.001
SLIPPAGE_BPS=300

# false = only simulate. true = send after simulate succeeds.
SEND_TX=false
